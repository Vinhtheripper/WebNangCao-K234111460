# Environment Configuration Example
# Copy file này và đổi tên thành .env hoặc .env.local

# ==========================================
# MOMO PAYMENT CONFIGURATION
# ==========================================

# Test Environment
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=F8590A41996C23F34
MOMO_SECRET_KEY=7862E3F3FD4D3D3DE33B3D3D3F3F3F3F
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway

# Production Environment (Uncomment khi sẵn sàng)
# MOMO_PARTNER_CODE=YOUR_PRODUCTION_PARTNER_CODE
# MOMO_ACCESS_KEY=YOUR_PRODUCTION_ACCESS_KEY
# MOMO_SECRET_KEY=YOUR_PRODUCTION_SECRET_KEY
# MOMO_ENDPOINT=https://payment.momo.vn/v2/gateway

# ==========================================
# SERVER CONFIGURATION
# ==========================================
SERVER_PORT=3000
SERVER_HOST=localhost

# ==========================================
# CORS CONFIGURATION
# ==========================================
CORS_ORIGIN=http://localhost:4200
CORS_CREDENTIALS=true

# ==========================================
# PAYMENT CONFIGURATION
# ==========================================
MIN_AMOUNT=10000
MAX_AMOUNT=999999999
PAYMENT_TIMEOUT=10000

# ==========================================
# WEBHOOK CONFIGURATION
# ==========================================
IPN_URL=http://localhost:3000/api/payment/momo/ipn
REDIRECT_URL=http://localhost:4200/payment-result

# ==========================================
# DATABASE CONFIGURATION (Future)
# ==========================================
# DB_HOST=localhost
# DB_PORT=27017
# DB_NAME=momo_payment
# DB_USER=admin
# DB_PASSWORD=password

# ==========================================
# EMAIL CONFIGURATION (Future)
